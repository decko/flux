# Flux environment variables
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit your tokens.

# Required: JWT signing secret (at least 16 characters)
JWT_SECRET=your-secret-key-at-least-16-chars

# GitHub authentication (choose one):

# Option A: GitHub App (recommended — per-project, short-lived tokens)
# 1. Register a GitHub App at https://github.com/settings/apps
# 2. Set repository permissions: Issues (Read/Write), Pull Requests (Read)
# 3. Generate and download a private key (.pem file)
# 4. Install the App on the repos you want Flux to manage
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----

# Option B: Personal Access Token (fallback — single token for all projects)
# Create a classic token at https://github.com/settings/tokens
# Requires: repo scope
# GITHUB_TOKEN=ghp_your-token-here
