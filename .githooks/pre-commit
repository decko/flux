#!/bin/bash
# Flux pre-commit hook
# Runs gofmt, golangci-lint, and tests before allowing commit.

set -e

# Ensure go binaries are on PATH
export PATH="$(go env GOPATH)/bin:$PATH"

echo "==> Running gitleaks..."
if command -v gitleaks &> /dev/null; then
    gitleaks protect --staged --no-banner -v 2>&1 || {
        echo "ERROR: gitleaks detected secrets in staged files."
        exit 1
    }
else
    echo "WARNING: gitleaks not installed. Skipping secret scan."
    echo "Install: go install github.com/zricethezav/gitleaks/v8@latest"
fi

echo "==> Running gofmt..."
unformatted=$(gofmt -l .)
if [ -n "$unformatted" ]; then
    echo "ERROR: Unformatted Go files found:"
    echo "$unformatted"
    echo "Run 'gofmt -s -w .' to fix."
    exit 1
fi

echo "==> Running golangci-lint..."
golangci-lint run

echo "==> Running tests..."
go test -race -short ./...

# Frontend checks (if web/ has changes)
if git diff --cached --name-only | grep -q "^web/"; then
    echo "==> Running frontend typecheck..."
    cd web && bun run typecheck
    echo "==> Running frontend lint..."
    bun run lint
fi

echo "==> All checks passed."
