# Flux self-host configuration example.
# Copy to flux.yaml and fill in your values.

server:
  # Port the web UI and API listen on.
  port: 8080

database:
  # SQLite database file path. :memory: for ephemeral, a path for persistent.
  path: flux.db

cors:
  # Allowed CORS origin. Use * for development.
  origin: "*"

logging:
  # Log level: debug, info, warn, error
  level: info

sync:
  # How often to poll adapters for new data.
  interval: 5m

adapters:
  # GitHub adapter — syncs issues and pull requests.
  # Authentication is handled by GITHUB_APP_ID + GITHUB_APP_PRIVATE_KEY env vars.
  # installation_id is the GitHub App installation ID for this repo.
  # Fallback: if installation_id is 0, uses GITHUB_TOKEN env var instead.
  - type: github
    owner: decko
    repo: flux
    installation_id: 0  # set to your App installation ID

orchestrators:
  # soda pipeline runner. Path defaults to "soda" (looked up in $PATH).
  # self_user is required when pipelines are configured — it prevents
  # infinite loops by filtering out events triggered by your own bot.
  - type: soda
    path: soda
    self_user: flux-bot
    pipelines:
      - name: default
        config: {}
      - name: quick-fix
        config:
          agent_count: 2
          max_tokens: 8000
