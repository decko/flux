# Flux configuration example
# Copy to flux.yaml and fill in your values.

server:
  host: 0.0.0.0
  port: 8080

database:
  driver: sqlite
  dsn: ./flux.db

auth:
  jwt_secret: ${FLUX_JWT_SECRET}

projects:
  - name: my-project
    repo: https://github.com/user/repo
    adapters:
      - type: github
        token: ${GITHUB_TOKEN}
    orchestrators:
      - type: soda
        path: ./soda.yaml
